# Copy to human_behaviour/.env — never commit real secrets.
# Loaded on API startup (see src/env_bootstrap.py).

# --- Grafana (docker-compose) ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

# --- Database ---
# Local SQLite default if unset. For Postgres on host (Docker maps DB to localhost:5433):
# DATABASE_URL=postgresql+psycopg2://hb_user:hb_password@127.0.0.1:5433/human_behaviour
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/mydb

# --- API auth / JWT ---
HB_API_AUTH=true
HB_JWT_SECRET=change-me-use-long-random-string
HB_JWT_ALGORITHM=HS256
HB_JWT_EXPIRE_MIN=120
# Aliases also supported: SECRET_KEY, ALGORITHM, ACCESS_TOKEN_EXPIRE_MINUTES

HB_API_USERS_JSON={"admin":{"password":"admin","role":"admin"},"analyst":{"password":"analyst","role":"analyst"},"viewer":{"password":"viewer","role":"viewer"}}

# --- LLM (host Ollama; from API container use host.docker.internal) ---
HB_OLLAMA_URL=http://127.0.0.1:11434
HB_OLLAMA_MODEL=llama3.1:8b

# --- Large multipart uploads (MiB per part) ---
# HB_MAX_MULTIPART_PART_MB=512

# --- CORS (optional) ---
# HB_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# HB_CORS_CREDENTIALS=false
