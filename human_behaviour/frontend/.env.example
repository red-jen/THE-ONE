# Call API in the browser without /api (fixes 413 with vite preview or strict proxies).
# Use in .env / .env.local / .env.production as needed.
VITE_API_ORIGIN=http://127.0.0.1:8000
# Docker API on host:
# VITE_API_ORIGIN=http://127.0.0.1:8010

# Alias of VITE_API_ORIGIN (either works).
# VITE_API_DIRECT_URL=http://127.0.0.1:8000

# Only for /api proxy (dev + preview) when not using VITE_API_ORIGIN.
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
